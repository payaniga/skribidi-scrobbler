{
  "manifest_version": 3,
  "name": "YTM Cookie Refresher",
  "version": "1.0",
  "description": "Automatically refreshes YouTube Music cookies in GitHub Secrets for the skribidi scrobbler.",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://www.youtube.com/*",
    "https://accounts.google.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YTM Cookie Refresher"
  },
  "options_page": "options.html"
}
